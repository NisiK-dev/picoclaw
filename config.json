    {
      "model_name": "openrouter-gpt4",
      "model": "openai/gpt-4o",
      "api_key": "OPENROUTER_API_KEY_PLACEHOLDER",
      "api_base": "https://openrouter.ai/api/v1",
      "request_timeout": 120
    }
