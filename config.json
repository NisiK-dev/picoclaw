{
  "agents": {
    "defaults": {
      "workspace": "/opt/render/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "model_name": "gpt4",
      "max_tokens": 8192,
      "temperature": 0.7,
      "max_tool_iterations": 20
    }
  },
  "model_list": [
    {
      "model_name": "gpt4",
      "model": "openai/gpt-4o",
      "api_key": "OPENAI_API_KEY_PLACEHOLDER",
      "api_base": "https://api.openai.com/v1",
      "request_timeout": 120
    },
    {
      "model_name": "gpt4-mini",
      "model": "openai/gpt-4o-mini",
